    "AMAX_delay": { "bits": 32, "default": 32 },
    "AMAX_len": { "bits": 16, "default": 5 },
    "PRETRIGGER_INPUT": { "bits": 32, "default": 600 },
    "PRETRIGGER_TRAP": { "bits": 32, "default": 600 },
