    "TRIG_M": { "bits": 16, "default": 12 },
    "TRAP_K": { "bits": 16, "default": 500 },
    "TRAP_M": { "bits": 16, "default": 550 },
    "DECONV_M": { "bits": 24, "default": 3499000 },
    "TRAP_GAIN": { "bits": 24, "default": 2500 },
    "BL_LEN": { "bits": 4, "default": 6 },
    "BL_INIB": { "bits": 16, "default": 1200 },
    "SAMPLE_POS": { "bits": 16, "default": 1800 },
    "RUN_CFG": { "bits": 1, "default": 1 },
    "WINDOW_MAXIM": { "bits": 32, "default": 500 },
    "baseline_delay": { "bits": 32, "default": 200 },
    "baseline_len": { "bits": 16, "default": 6 },
