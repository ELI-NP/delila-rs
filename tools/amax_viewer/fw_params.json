{
  "_comment": "AMax firmware parameter table: bit widths, defaults, and UI metadata.",
  "_usage_amax_viewer": "cargo run --bin gen_defs -- RegisterFile.json -p fw_params.json -o register_defs.json",
  "_usage_delila_rs": "cargo run --bin amax_codegen -- <RegisterFile.json>  (writes Rust + TS sources)",
  "_matching": "Keys are matched as substrings of register names (e.g. 'THRS' matches 'page_amax_energy_0_THRS').",
  "_ui_meta_fields": "label/category/type/options/ui_max/unit are consumed by amax_codegen only; amax_viewer ignores them.",
  "params": {
    "POLARITY":         { "bits": 1,  "default": 1,       "label": "Polarity",       "category": "input",    "type": "enum",   "options": ["0", "1"] },
    "OFFSET":           { "bits": 16, "default": 0,       "label": "DC Offset",      "category": "input",    "type": "number" },
    "THRS":             { "bits": 32, "default": 20,      "label": "Threshold",      "category": "trigger",  "type": "number", "ui_max": 1000000 },
    "TRIG_K":           { "bits": 16, "default": 10,      "label": "Fast Trig Rise", "category": "trigger",  "type": "number", "unit": "samp" },
    "TRIG_M":           { "bits": 16, "default": 12,      "label": "Fast Trig Decay","category": "trigger",  "type": "number", "unit": "samp" },
    "TRAP_K":           { "bits": 16, "default": 500,     "label": "Trap Rise",      "category": "energy",   "type": "number", "unit": "samp" },
    "TRAP_M":           { "bits": 16, "default": 550,     "label": "Trap Decay",     "category": "energy",   "type": "number", "unit": "samp" },
    "DECONV_M":         { "bits": 24, "default": 3499000, "label": "Deconvolution",  "category": "energy",   "type": "number" },
    "TRAP_GAIN":        { "bits": 24, "default": 2500,    "label": "Trap Gain",      "category": "energy",   "type": "number" },
    "BL_LEN":           { "bits": 4,  "default": 6,       "label": "BL Length (MCA)","category": "energy",   "type": "number" },
    "BL_INIB":          { "bits": 16, "default": 1200,    "label": "BL Inhibit",     "category": "energy",   "type": "number", "unit": "samp" },
    "SAMPLE_POS":       { "bits": 16, "default": 1800,    "label": "Sample Pos",     "category": "energy",   "type": "number", "unit": "samp" },
    "RUN_CFG":          { "bits": 1,  "default": 1,       "label": "Run Enable",     "category": "input",    "type": "enum",   "options": ["0", "1"] },
    "WINDOW_MAXIM":     { "bits": 32, "default": 500,     "label": "Max Window",     "category": "energy",   "type": "number", "unit": "samp", "ui_max": 1000000 },
    "baseline_delay":   { "bits": 32, "default": 200,     "label": "BL Delay (AMax)","category": "energy",   "type": "number", "unit": "samp", "ui_max": 1000000 },
    "baseline_len":     { "bits": 16, "default": 6,       "label": "BL Length (AMax)","category": "energy",  "type": "number" },
    "baseline_offset":  { "bits": 16, "default": 1000,    "label": "BL Offset (AMax)","category": "energy",  "type": "number" },
    "AMAX_window":      { "bits": 32, "default": 1000,    "label": "AMax Window",    "category": "energy",   "type": "number", "unit": "samp", "ui_max": 1000000 },
    "AMAX_delay":       { "bits": 32, "default": 32,      "label": "AMax Delay",     "category": "energy",   "type": "number", "unit": "samp", "ui_max": 1000000 },
    "AMAX_len":         { "bits": 16, "default": 5,       "label": "AMax Length",    "category": "energy",   "type": "number", "unit": "samp" },
    "PRETRIGGER_INPUT": { "bits": 32, "default": 600,     "label": "Pretrig Input",  "category": "waveform", "type": "number", "unit": "samp", "ui_max": 1000000 },
    "PRETRIGGER_TRAP":  { "bits": 32, "default": 600,     "label": "Pretrig Trap",   "category": "waveform", "type": "number", "unit": "samp", "ui_max": 1000000 },
    "PRETRIGGER_AMAX":  { "bits": 32, "default": 600,     "label": "Pretrig AMax",   "category": "waveform", "type": "number", "unit": "samp", "ui_max": 1000000 },
    "selector_wave":    { "bits": 1,  "default": 0,       "label": "Wave Selector",  "category": "waveform", "type": "enum",   "options": ["0", "1"] }
  },
  "readonly_patterns": [
    "ENERGY_MAIN",
    "AMAX_MAIN",
    "ENERGY_MAIN_LATCH",
    "debug_amax_out",
    "READ_ENERGY",
    "maxim_outt"
  ]
}
